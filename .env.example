# Configurações do Banco de Dados
# Preencha a URI abaixo para usar o MongoDB. Se deixar vazio, o sistema usará o arquivo JSON local.
MONGODB_URI=

# Segurança - JWT
# IMPORTANTE: Em produção, mude para strings longas e aleatórias (ex: geradas com node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=segredo_para_funcionarios_desenvolvimento
ADMIN_JWT_SECRET=segredo_para_admin_desenvolvimento

# Porta do Servidor
PORT=3000

# Configurações de E-mail para Notificações (Opcional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL=
